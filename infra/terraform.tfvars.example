# ============================================
# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored - do not ever commit it.
# ============================================

gcp_project_id      = "your-gcp-project-id"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Optional overrides (defaults match current lab config)
# gcp_region             = "us-south1"
# gcp_zone               = "us-south1-a"
# core_machine_type      = "t2d-standard-2"
# ueransim_machine_type  = "t2d-standard-1"
# core_disk_size_gb      = 30
# ueransim_disk_size_gb  = 10
# core_5g_ip             = "10.0.2.3"
# ueransim_ip            = "10.0.2.2"
# grafana_admin_password = "your-strong-password-here"